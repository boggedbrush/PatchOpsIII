{
  "name": "patchopsiii-electron",
  "version": "1.2.2",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "bun run build:main && bun scripts/dev.ts",
    "dev:server": "bun scripts/dev-server.ts",
    "build": "bun run typecheck && bun run build:main && vite build",
    "build:main": "tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit",
    "start": "bun run build:main && electron ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^31.0.0",
    "lucide-react": "^0.468.0",
    "vite": "^5.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/bun": "^1.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
